# Default behavior, in case folks don't have core.autocrlf set
* text=auto

# Web and JS files
*.js text
*.ts text
*.tsx text
*.jsx text
*.json text
*.css text
*.html text
*.svg text

# Python files
*.py text

# Documentation & Configs
*.md text
*.yml text
*.yaml text

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
